# MongoDB 配置
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=adminpwd
MONGO_INITDB_DATABASE=mycampus

# 应用数据库用户配置
MYCAMPUS_DB_USER=mycampus_user
MYCAMPUS_DB_PASSWORD=mycampus_password

# Spring Boot 应用配置
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080

# 网络配置
MONGODB_PORT=27017
APP_PORT=8080

# Docker镜像加速器配置
# 请根据您的服务器所在地区选择合适的镜像加速器

# 阿里云镜像加速器（推荐用于阿里云服务器）
DOCKER_REGISTRY_MIRROR=

# 其他可选的镜像加速器：
# 中科大镜像加速器
# DOCKER_REGISTRY_MIRROR=https://docker.mirrors.ustc.edu.cn

# Docker中国官方镜像加速器
# DOCKER_REGISTRY_MIRROR=https://registry.docker-cn.com

# 网易云镜像加速器
# DOCKER_REGISTRY_MIRROR=https://hub-mirror.c.163.com

# 腾讯云镜像加速器
# DOCKER_REGISTRY_MIRROR=https://mirror.ccs.tencentyun.com

# 华为云镜像加速器
# DOCKER_REGISTRY_MIRROR=https://05f073ad3c0010ea0f4bc00b7105ec20.mirror.swr.myhuaweicloud.com

# 如果不需要使用镜像加速器（例如在海外服务器），可以使用官方镜像：
# DOCKER_REGISTRY_MIRROR=docker.io